@model dominio.Disco

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Disco</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Titulo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Titulo)
        </dd>
        <dt class="col-sm-2">
            Fecha Lanzamiento
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FechaLanzamiento.Day)/@Html.DisplayFor(model => model.FechaLanzamiento.Month)/@Html.DisplayFor(model => model.FechaLanzamiento.Year)
        </dd>
        <dt class="col-sm-2">
            Cantidad Canciones
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CantidadCanciones)
        </dd>
        <dt class="col-sm-2">
            Tipo Edicion
        </dt>
        <dd class="col-sm-10">
            @Model.TipoEdicion.Descripcion
        </dd>
        <dt class="col-sm-2">
            Estilo
        </dt>
        <dd class="col-sm-10">
            @Model.Estilo.Descripcion
        </dd>
        <dd class="col-sm-10">
            <img src="@Model.UrlTapa" height="150">
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" > Edit </a> <br />
    <a asp-action="Index">Back to List</a>
</div>
